# Application
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:5173

# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# JWT — use a strong random secret in production (openssl rand -base64 64)
JWT_SECRET=REPLACE_ME_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=24h

# Parking Rent
RATE_DAILY=250

# Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=5
