# Application
NODE_ENV=development
PORT=3000

# Database
# SQLite (local dev):
DATABASE_URL="file:./dev.db"
# PostgreSQL (production):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT — use a strong random secret in production (openssl rand -base64 64)
JWT_SECRET=REPLACE_ME_WITH_STRONG_RANDOM_SECRET
JWT_EXPIRES_IN=24h

# Parking Rates (per hour in local currency)
RATE_MOTORCYCLE=2000
RATE_CAR=5000
RATE_TRUCK=10000

# Upload
UPLOAD_DEST=./uploads
MAX_FILE_SIZE_MB=5
